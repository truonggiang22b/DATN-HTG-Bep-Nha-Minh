// schema.prisma — Bếp Nhà Mình — QR Ordering System
// Spec reference: 14_be_mvp_spec_node_express_ts.md Section 8

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum OrderStatus {
  NEW
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum OrderType {
  DINE_IN
  ONLINE
}

enum DeliveryStatus {
  PENDING
  ACCEPTED
  PREPARING
  DELIVERING
  DELIVERED
  CANCELLED
}

enum MenuItemStatus {
  ACTIVE
  SOLD_OUT
  HIDDEN
}

enum CategoryStatus {
  ACTIVE
  HIDDEN
}

enum TableStatus {
  ACTIVE
  INACTIVE
}

enum SessionStatus {
  OPEN
  CLOSED
}

enum UserRole {
  ADMIN
  MANAGER
  KITCHEN
}

// ─── Multi-tenant root ────────────────────────────────────────────────────────

model Store {
  id        String   @id @default(uuid())
  name      String
  timezone  String   @default("Asia/Ho_Chi_Minh")
  createdAt DateTime @default(now()) @map("created_at")

  branches Branch[]
  users    User[]
  orders   Order[]

  @@map("stores")
}

model Branch {
  id        String   @id @default(uuid())
  storeId   String   @map("store_id")
  name      String
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // ── Phase 2: Delivery config (optional, null = tính năng chưa bật) ──────────
  latitude         Float?
  longitude        Float?
  deliveryBaseKm   Float?  @default(2)     @map("delivery_base_km")
  deliveryBaseFee  Int?    @default(15000) @map("delivery_base_fee")
  deliveryFeePerKm Int?    @default(5000)  @map("delivery_fee_per_km")
  deliveryMaxKm    Float?  @default(10)    @map("delivery_max_km")

  store        Store         @relation(fields: [storeId], references: [id])
  diningTables DiningTable[]
  categories   Category[]
  orders       Order[]

  @@map("branches")
}

// ─── Users & Roles ────────────────────────────────────────────────────────────

model User {
  id                 String   @id @default(uuid())
  supabaseAuthUserId String   @unique @map("supabase_auth_user_id")
  storeId            String   @map("store_id")
  defaultBranchId    String?  @map("default_branch_id")
  displayName        String   @map("display_name")
  email              String
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")

  store              Store                @relation(fields: [storeId], references: [id])
  roles              UserRole_Rel[]
  orderStatusHistory OrderStatusHistory[]

  @@index([storeId, email])
  @@map("users")
}

model UserRole_Rel {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  role      UserRole
  storeId   String   @map("store_id")
  branchId  String?  @map("branch_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_roles")
}

// ─── Tables & Sessions ────────────────────────────────────────────────────────

model DiningTable {
  id          String      @id @default(uuid())
  branchId    String      @map("branch_id")
  tableCode   String      @map("table_code")
  displayName String      @map("display_name")
  qrToken     String      @unique @map("qr_token")
  status      TableStatus @default(ACTIVE)
  createdAt   DateTime    @default(now()) @map("created_at")

  branch   Branch         @relation(fields: [branchId], references: [id])
  sessions TableSession[]
  orders   Order[]

  @@unique([branchId, tableCode])
  @@map("dining_tables")
}

model TableSession {
  id           String        @id @default(uuid())
  tableId      String        @map("table_id")
  status       SessionStatus @default(OPEN)
  openedAt     DateTime      @default(now()) @map("opened_at")
  closedAt     DateTime?     @map("closed_at")
  orderCounter Int           @default(0) @map("order_counter")
  createdAt    DateTime      @default(now()) @map("created_at")

  table  DiningTable @relation(fields: [tableId], references: [id])
  orders Order[]

  @@index([tableId, status, openedAt(sort: Desc)])
  @@map("table_sessions")
}

// ─── Menu ─────────────────────────────────────────────────────────────────────

model Category {
  id        String         @id @default(uuid())
  branchId  String         @map("branch_id")
  name      String
  sortOrder Int            @default(0) @map("sort_order")
  status    CategoryStatus @default(ACTIVE)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  branch    Branch     @relation(fields: [branchId], references: [id])
  menuItems MenuItem[]

  @@map("categories")
}

model MenuItem {
  id               String         @id @default(uuid())
  categoryId       String         @map("category_id")
  name             String
  price            Decimal        @db.Decimal(10, 0)
  imageUrl         String?        @map("image_url")
  shortDescription String?        @map("short_description")
  ingredients      String?
  tagsJson         Json           @default("[]") @map("tags_json")
  status           MenuItemStatus @default(ACTIVE)
  sortOrder        Int            @default(0) @map("sort_order")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  category     Category          @relation(fields: [categoryId], references: [id])
  optionGroups MenuOptionGroup[]
  orderItems   OrderItem[]

  @@index([categoryId, status, sortOrder])
  @@map("menu_items")
}

model MenuOptionGroup {
  id         String  @id @default(uuid())
  menuItemId String  @map("menu_item_id")
  name       String
  isRequired Boolean @default(false) @map("is_required")
  minSelect  Int     @default(0) @map("min_select")
  maxSelect  Int     @default(1) @map("max_select")
  sortOrder  Int     @default(0) @map("sort_order")

  menuItem MenuItem     @relation(fields: [menuItemId], references: [id])
  options  MenuOption[]

  @@map("menu_option_groups")
}

model MenuOption {
  id            String  @id @default(uuid())
  optionGroupId String  @map("option_group_id")
  name          String
  priceDelta    Decimal @default(0) @map("price_delta") @db.Decimal(10, 0)
  isActive      Boolean @default(true) @map("is_active")
  sortOrder     Int     @default(0) @map("sort_order")

  optionGroup MenuOptionGroup @relation(fields: [optionGroupId], references: [id])

  @@map("menu_options")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(uuid())
  storeId         String      @map("store_id")
  branchId        String      @map("branch_id")
  tableId         String?     @map("table_id")         // nullable: online orders have no table
  tableSessionId  String?     @map("table_session_id") // nullable: online orders have no session
  clientSessionId String      @map("client_session_id")
  orderCode       String      @map("order_code")
  status          OrderStatus @default(NEW)
  orderType       OrderType   @default(DINE_IN)        @map("order_type")  // Phase 2
  subtotal        Decimal     @db.Decimal(10, 0)
  customerNote    String?     @map("customer_note")
  idempotencyKey  String      @unique @map("idempotency_key")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  store         Store                @relation(fields: [storeId], references: [id])
  branch        Branch               @relation(fields: [branchId], references: [id])
  table         DiningTable?         @relation(fields: [tableId], references: [id])
  tableSession  TableSession?        @relation(fields: [tableSessionId], references: [id])
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  deliveryInfo  DeliveryInfo?        // Phase 2: only for ONLINE orders

  @@index([tableSessionId, createdAt(sort: Desc)])
  @@index([storeId, branchId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Asc)])
  @@index([orderType, createdAt(sort: Desc)])            // Phase 2: filter by type
  @@map("orders")
}

model OrderItem {
  id                          String  @id @default(uuid())
  orderId                     String  @map("order_id")
  menuItemId                  String  @map("menu_item_id")
  nameSnapshot                String  @map("name_snapshot")
  priceSnapshot               Decimal @map("price_snapshot") @db.Decimal(10, 0)
  quantity                    Int
  selectedOptionsSnapshotJson Json    @default("[]") @map("selected_options_snapshot_json")
  note                        String? @default("")
  lineTotal                   Decimal @map("line_total") @db.Decimal(10, 0)

  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

model OrderStatusHistory {
  id              String       @id @default(uuid())
  orderId         String       @map("order_id")
  fromStatus      OrderStatus? @map("from_status")
  toStatus        OrderStatus  @map("to_status")
  reason          String?
  changedByUserId String?      @map("changed_by_user_id")
  changedAt       DateTime     @default(now()) @map("changed_at")

  order         Order @relation(fields: [orderId], references: [id])
  changedByUser User? @relation(fields: [changedByUserId], references: [id])

  @@index([orderId, changedAt(sort: Desc)])
  @@map("order_status_history")
}

// ─── Phase 2: Delivery Info ───────────────────────────────────────────────────

model DeliveryInfo {
  id             String         @id @default(uuid())
  orderId        String         @unique @map("order_id")
  customerName   String         @map("customer_name")
  phone          String
  address        String
  ward           String?
  district       String?
  customerLat    Float?         @map("customer_lat")
  customerLng    Float?         @map("customer_lng")
  distanceKm     Float?         @map("distance_km")
  shippingFee    Int            @default(0) @map("shipping_fee")
  deliveryStatus DeliveryStatus @default(PENDING) @map("delivery_status")
  note           String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("delivery_infos")
}
