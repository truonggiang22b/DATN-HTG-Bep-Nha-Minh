# Backend — Production Environment Template
# Copy file này thành `.env.production` hoặc set trực tiếp trên Railway/Render.
#   copy .env.production.example .env   (chỉ dùng local test prod mode)
#
# ⚠️  KHÔNG commit file .env thật vào git — đã được .gitignore bảo vệ.
# ⚠️  Rotate tất cả secrets dưới đây sau lần đầu deploy.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
# URL công khai của backend sau khi deploy (dùng cho CORS & link building)
APP_BASE_URL=https://your-backend.up.railway.app
# URL của frontend đã deploy (dùng cho CORS whitelist)
FRONTEND_URL=https://your-frontend.vercel.app

# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Lấy từ: Supabase Dashboard → Settings → Database → Connection string → URI
# Dùng "Transaction pooler" URL cho production (PgBouncer port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection — dùng cho Prisma migrate (không qua pooler)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Lấy từ: Supabase Dashboard → Settings → API
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
# "Publishable" key — có thể dùng phía client (anon, read-only)
SUPABASE_ANON_KEY="sb_publishable_..."
# "Secret" key — chỉ dùng server-side, KHÔNG để lộ
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."
# JWT Secret — Supabase Dashboard → Settings → Data API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET="your-real-jwt-secret-here"

# ─── Storage ──────────────────────────────────────────────────────────────────
# Tên bucket Supabase Storage để lưu ảnh menu (phải tạo bucket trên dashboard)
# Dashboard: Storage → New bucket → Name: menu-images → ☑ Public
SUPABASE_STORAGE_BUCKET=menu-images
