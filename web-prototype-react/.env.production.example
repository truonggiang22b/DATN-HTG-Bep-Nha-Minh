# Frontend — Production Environment Template
# Copy file này thành `.env.production` và điền đúng giá trị trước khi build:
#   copy .env.production.example .env.production   (Windows)
#   cp   .env.production.example .env.production   (Linux/Mac)
#
# Sau đó chạy: npm run build
# ─── Hoặc ─────────────────────────────────────────────────────────────────────
# Set env var trực tiếp trên Vercel Dashboard (khuyến nghị — không cần file):
#   Project Settings → Environment Variables → VITE_API_URL

# URL của backend API đã deploy (Railway / Render / VPS)
# KHÔNG có trailing slash, KHÔNG có /api ở cuối — client tự thêm /api
VITE_API_URL=https://your-backend.up.railway.app/api
