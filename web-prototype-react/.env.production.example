# Frontend - Production Environment Template
#
# Use this value in Vercel Project Settings -> Environment Variables,
# or copy this file to `.env.production` before running `npm run build`.
#
# Important:
# - VITE_API_URL must include the backend API prefix `/api`.
# - Do not add a trailing slash.

VITE_API_URL=https://your-backend.up.railway.app/api
